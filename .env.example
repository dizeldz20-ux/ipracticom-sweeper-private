# iPracticom Sweeper — Environment Variables
# Copy to .env and fill in the values you need.

# --- Agent API auth (optional but recommended) ---
# If set, the agent_api requires this token for all endpoints.
# If unset, the API runs in OPEN mode (bind to localhost only).
# AGENT_API_TOKEN=change-me-to-a-long-random-string

# --- Notification channels (at least one) ---
# Slack incoming webhook URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Telegram bot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=-1001234567890

# --- Runbook safety ---
# Default: dry-run (actions logged but not executed)
RUNBOOK_DRY_RUN=true
# If true, destructive actions (kill, drop_caches) require explicit approval
RUNBOOK_REQUIRE_APPROVAL=true

# --- Dedup window (seconds) ---
# 0 disables dedup. Default: 300 (5 min).
AGENT_DEDUP_WINDOW_SEC=300

# --- Token rotation (optional, off by default) ---
# Set to "true" to enable AGENT_TOKEN_<YYYYMMDD> env var lookup
AGENT_TOKEN_ROTATION_ENABLED=false
