# iPracticom Sweeper — environment file
# Copy to /etc/ipracticom-sweeper.env and fill in

# Slack — incoming webhook URL from your Slack workspace
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Telegram — bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AWS region (defaults to il-central-1 if unset)
AWS_REGION=il-central-1